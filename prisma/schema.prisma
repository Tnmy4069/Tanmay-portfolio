// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model About {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String   @default("TANMAY HIRODKAR")
  tagline   String
  subtitle  String   @default("Building scalable systems, leading technology programs, and crafting digital experiences that bridge AI, cloud, and human-centered design.")
  bio       String
  email     String   @default("tnmy.web@gmail.com")
  phone     String   @default("+91 83800 66588")
  github    String   @default("https://github.com/Tnmy4069")
  linkedin  String   @default("https://linkedin.com/in/hirodkar")
  portfolio String   @default("https://tnmyh.vercel.app")
  theme     String   @default("cyan")
  updatedAt DateTime @updatedAt
}

model Skill {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  category String // e.g., "frontend", "backend", "data", "tools"
  name     String // e.g., "React.js"

  @@unique([category, name])
}

model Experience {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  role        String
  company     String
  duration    String
  description String
}

model Education {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  degree      String
  institution String
  year        String
}

model Project {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  desc      String
  link      String
  linkLabel String
  span      Boolean  @default(false)
  tags      String   // Using a simple serialized string like "React:, Tailwind:purple"
}

model Achievement {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  number    String
  label     String
  span      Boolean  @default(false)
}

model Leadership {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  role      String
  org       String
  period    String
  points    String   // Newline separated
}

model Blog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  slug      String   @unique
  content   String
  imageUrl  String?
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
